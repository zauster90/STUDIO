  <link rel="stylesheet" href="" id="theme-css">

  <style>
    /* ── Theme switcher bar — neutral, stays consistent across all themes ── */
    .theme-bar {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 9999;
      background: #2a2a2a;
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.65rem 1.5rem;
      font-family: -apple-system, Helvetica, Arial, sans-serif;
      box-shadow: 0 2px 12px rgba(0,0,0,0.25);
    }

    .theme-bar-label {
      color: #999999;
      font-size: 0.65rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      margin-right: 0.5rem;
      white-space: nowrap;
    }

    .theme-btn {
      background: transparent;
      color: #cccccc;
      border: 1px solid #555555;
      padding: 0.35rem 0.85rem;
      font-size: 0.7rem;
      font-family: -apple-system, Helvetica, Arial, sans-serif;
      letter-spacing: 0.04em;
      cursor: pointer;
      transition: all 0.15s ease;
      border-radius: 3px;
      white-space: nowrap;
    }

    .theme-btn:hover {
      background: #444444;
      color: #ffffff;
      border-color: #777777;
    }

    .theme-btn.active {
      background: #ffffff;
      color: #1a1a1a;
      border-color: #ffffff;
      font-weight: 600;
    }

    /* Push page content below the fixed bar */
    .page {
      margin-top: 52px;
    }

    /* ── Review section labels ── */
    .review-section-label {
      font-family: -apple-system, Helvetica, Arial, sans-serif;
      font-size: 0.6rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: #999999;
      background: #2a2a2a;
      display: inline-block;
      padding: 0.2rem 0.6rem;
      border-radius: 2px;
      margin-bottom: 1.5rem;
    }

    /* ── Responsive bar ── */
    @media (max-width: 640px) {
      .theme-bar {
        flex-wrap: wrap;
        gap: 0.35rem;
        padding: 0.5rem 0.75rem;
      }
      .theme-bar-label {
        width: 100%;
        margin-bottom: 0.15rem;
      }
      .theme-btn {
        font-size: 0.6rem;
        padding: 0.3rem 0.6rem;
      }
      .page {
        margin-top: 88px;
      }
    }
  </style>
</head>
