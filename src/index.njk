---
layout: layouts/base.njk
title: ""
activeNav: work
---

<div class="gallery-header gallery-header--featured" data-reveal>
  <h2 class="gallery-title">Featured Work</h2>
</div>

{% set featuredWorks = collections.works | featured | limit(1) %}
{% for work in featuredWorks %}
<div class="featured-work" data-reveal>
  <div class="featured-image-wrap">
    <a href="{{ work.url }}">
      <img src="{{ work.data.image }}"
           alt="{{ work.data.title }}, {{ work.data.year }} — {{ work.data.medium }}, {{ work.data.dimensions }}"
           width="1200" height="1200"
           loading="eager">
    </a>
  </div>
  <div class="work-meta">
    <div class="work-meta-row">
      <span class="work-meta-key">Title</span>
      <span class="work-meta-val"><strong>{{ work.data.title }}</strong>, {{ work.data.year }}</span>
    </div>
    <div class="work-meta-row">
      <span class="work-meta-key">Medium</span>
      <span class="work-meta-val">{{ work.data.medium }}</span>
    </div>
    {% if work.data.dimensions %}
    <div class="work-meta-row">
      <span class="work-meta-key">Dimensions</span>
      <span class="work-meta-val">{{ work.data.dimensions }}</span>
    </div>
    {% endif %}
  </div>
</div>
{% endfor %}

<!-- Lightbox -->
<div class="lightbox" id="lightbox">
  <img src="" alt="">
</div>
<script src="/assets/js/lightbox.js" defer></script>
