---
layout: layouts/base.njk
title: About
activeNav: about
---

<div class="about-book" data-reveal>
  <!-- LEFT PAGE: Statement + Education -->
  <div class="about-left">
    <div class="about-statement">
      <p>{{ about.bio }}</p>

      <h2 class="section-heading">Artist Statement</h2>
      <blockquote class="artist-statement">
        {% for paragraph in about.artist_statement %}
          <p>{{ paragraph }}</p>
        {% endfor %}
      </blockquote>
    </div>

    <div class="cv-section">
      <h2 class="section-heading">Education</h2>
      <div class="cv-content">
        {% for edu in about.education %}
        <div class="cv-entry">
          <span class="cv-year"></span>
          <div class="cv-text"><strong>{{ edu.degree }}</strong>{{ edu.field }}<br>{{ edu.school }}<br>{{ edu.year }}</div>
        </div>
        {% endfor %}
      </div>
    </div>
  </div>

  <div class="about-spacer"></div>

  <!-- RIGHT PAGE: Exhibition Record -->
  <div class="about-right">
    <h2 class="exhibition-title">Exhibition Record</h2>
    <div class="exhibition-grid">
      {% set lastYear = null %}
      {% for exh in about.exhibitions %}
        <div class="exhibition-year">{% if exh.year != lastYear %}{{ exh.year }}{% endif %}</div>
        <div class="exhibition-entry"><strong>{{ exh.title }},</strong> {% if exh.type %}{{ exh.type }}, {% endif %}{% if exh.venue %}{{ exh.venue }}, {% endif %}{{ exh.location }}</div>
        {% set lastYear = exh.year %}
      {% endfor %}
    </div>
  </div>
</div>
